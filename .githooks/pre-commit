#!/usr/bin/env bash
#
# Qaymark pre-commit gate.
#
# Two layers of enforcement, version-controlled (core.hooksPath = .githooks) so
# any change is visible in the diff and reviewable — it is not meant to be
# silently edited or bypassed. Do not commit with --no-verify: CI runs the same
# checks and will reject the push.
#
#   1. Strict slop-be-gone hygiene on staged changes.
#   2. The behavioural invariants that keep the factory working (fast, no
#      network/servers) so a hard-won fix cannot silently regress.
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

python3 scripts/hygiene_gate.py --staged --path "$repo_root"

PYTHONPATH="$repo_root" python3 -m unittest tests.test_invariants
