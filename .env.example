# --- Model + Ollama runtime ---
OLLAMA_MODEL=qwen2.5-coder:3b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_PORT=11434
OLLAMA_KEEP_ALIVE=24h
# Browser clients allowed to call the Ollama API (comma-separated, or *).
# Needed so a deployed Waymark can drive your local Ollama.
OLLAMA_ORIGINS=*

# --- Open WebUI ---
# Defaults to 8095 so it does not collide with Waymark (3000 web, 8090 p2p).
WEBUI_PORT=8095
# Disabling auth only works on a fresh WebUI database (no existing users).
WEBUI_AUTH=False
ENABLE_SIGNUP=False
# Set to 1 to wipe the local WebUI database on bootstrap (needed the first
# time you switch WEBUI_AUTH from True to False). Destructive — default off.
RESET_WEBUI_DATA=0

# --- Harness ---
HARNESS_MAX_ATTEMPTS=3
# Set to 1 to allow the model's run_command operations (off by default).
HARNESS_ALLOW_COMMANDS=0
